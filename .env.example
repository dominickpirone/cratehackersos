# Environment variables for the Email Console (cloud deploy).
# Copy to a real .env for local testing, or set these in Render's dashboard.
# NEVER commit a filled-in version — .env is gitignored.

# ── Google sign-in (required to turn auth ON) ───────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=          # any random 32+ char string
ALLOWED_DOMAIN=cratehackers.com
# OAUTH_BASE_URL is auto-detected on Render. Set it only if hosting elsewhere,
# e.g. OAUTH_BASE_URL=https://console.cratehackers.com

# ── Where data + settings live (Render disk) ────────────────────────────
DATA_DIR=/data
CONFIG_PATH=/data/config.local.json

# ── Email (Postmark broadcast) ──────────────────────────────────────────
POSTMARK_SERVER_TOKEN=
FROM_EMAIL=dom@support.cratehackers.com
FROM_NAME=Dominick — CrateHackers.com
POSTMARK_STREAM=broadcast
REPLY_TO=

# ── Sales connections ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_ENV=live
KARTRA_APP_ID=
KARTRA_API_KEY=
KARTRA_API_PASSWORD=
SALES_LEDGER_CSV_URL=

# ── Email via Mailgun (optional alt provider) ───────────────────────────
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_REGION=us
MAILGUN_FROM_EMAIL=
MAILGUN_FROM_NAME=

# ── SMS (Twilio + Quo) ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBERS=
TWILIO_MESSAGING_SERVICE_SID=
QUO_API_KEY=
QUO_FROM_NUMBER=

# ── Test recipients (Send-test buttons) ─────────────────────────────────
TEST_EMAIL=dom@cratehackers.com
TEST_PHONE=
